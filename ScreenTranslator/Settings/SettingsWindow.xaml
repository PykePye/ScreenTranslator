<Window x:Class="ScreenTranslator.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — Screen Translator" Height="450" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Label Content="Gemini API Key:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <PasswordBox x:Name="ApiKeyBox" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="5,5"/>
        <Button Content="Test Key" Grid.Row="0" Grid.Column="2" Width="60" Margin="5" Click="OnTestKeyClick"/>

        <Label Content="Target Language:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="TargetLanguageCombo" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5,5">
            <ComboBoxItem Content="Vietnamese"/>
            <ComboBoxItem Content="English"/>
            <ComboBoxItem Content="Chinese"/>
            <ComboBoxItem Content="Japanese"/>
            <ComboBoxItem Content="Korean"/>
        </ComboBox>

        <Label Content="AI Model:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="ModelCombo" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5,5">
            <ComboBoxItem Content="gemini-2.5-flash"/>
            <ComboBoxItem Content="gemini-2.5-pro"/>
            <ComboBoxItem Content="gemini-2.0-flash"/>
            <ComboBoxItem Content="gemini-1.5-flash"/>
            <ComboBoxItem Content="gemini-1.5-pro"/>
        </ComboBox>

        <Label Content="Hotkey (Ctrl+Shift+?):" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,5"/>
        <ComboBox x:Name="HotkeyCombo" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="5,5">
            <ComboBoxItem Content="D"/>
            <ComboBoxItem Content="Z"/>
            <ComboBoxItem Content="S"/>
            <ComboBoxItem Content="Q"/>
            <ComboBoxItem Content="F"/>
        </ComboBox>

        <Button Content="List Available Models" Grid.Row="4" Grid.ColumnSpan="3" Margin="5" Click="OnListModelsClick"/>

        <TextBlock x:Name="TestStatusText" Grid.Row="5" Grid.ColumnSpan="3" TextWrapping="Wrap" Margin="5" Foreground="Gray" FontSize="11" Height="60"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="80" Margin="5" Click="OnSaveClick"/>
            <Button Content="Cancel" Width="80" Margin="5" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>