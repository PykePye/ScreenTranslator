<Window x:Class="ScreenTranslator.Snip.SnipOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross">
    <Grid x:Name="RootGrid">
        <!-- Layer 1: Mask đen alpha với lỗ khoét cho vùng đã chọn -->
        <Path x:Name="MaskPath" Fill="#80000000" IsHitTestVisible="False"/>

        <!-- Layer 2: Border viền của vùng selection -->
        <Rectangle x:Name="SelectionBorder"
                   Stroke="#FF4FC3F7"
                   StrokeThickness="2"
                   Fill="Transparent"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"/>

        <!-- Layer 3: Hint text giữa màn hình khi chưa chọn -->
        <TextBlock x:Name="HintText"
                   Text="Kéo chuột để chọn vùng cần dịch — Escape để hủy"
                   Foreground="White"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0"/>
            </TextBlock.Effect>
        </TextBlock>

        <!-- Layer 4: Hit-test layer — Canvas trong suốt nhận mouse events -->
        <Canvas x:Name="InputCanvas" Background="Transparent"/>
    </Grid>
</Window>