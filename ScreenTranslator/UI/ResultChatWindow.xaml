<Window x:Class="ScreenTranslator.UI.ResultChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Translation History (Current Session)" Height="500" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="True" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border CornerRadius="12" Background="#F5F5F7" BorderBrush="#D1D1D6" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Chat Area -->
                <RowDefinition Height="Auto"/> <!-- Footer/Status -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="12,12,0,0" BorderBrush="#D1D1D6" BorderThickness="0,0,0,1">
                <Grid Margin="10,0">
                    <TextBlock Text="Trợ lý ngôn ngữ của Bryan" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1C1C1E"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Nút Crop -->
                        <Button ToolTip="Chụp vùng mới" Content="" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Width="30" Click="Snip_Click"/>
                        <!-- Nút Reload -->
                        <Button ToolTip="Dịch lại ảnh cuối" Content="" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Width="30" Click="Reload_Click"/>
                        <Separator Width="1" Margin="5,8" Background="#D1D1D6"/>
                        <Button Content="" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Width="30" Click="Minimize_Click"/>
                        <Button Content="" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="0" Width="30" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chat Area -->
            <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Margin="5">
                <ItemsControl x:Name="ChatItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="MessageBorder" Margin="5" Padding="10" CornerRadius="8" 
                                    Background="#FFFFFF"
                                    BorderBrush="#E5E5EA" BorderThickness="1">
                                <StackPanel>
                                    <Image Source="{Binding ImageSnippet}" MaxHeight="150" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,0,0,8">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImageSnippet}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Text="{Binding TranslatedText}" TextWrapping="Wrap" Foreground="#1C1C1E" FontSize="14"/>
                                    <Grid Margin="0,5,0,0">
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" FontSize="10" Foreground="#8E8E93" HorizontalAlignment="Left"/>
                                        <Button Content="Copy" HorizontalAlignment="Right" FontSize="10" Padding="5,1" Click="Copy_Click" Tag="{Binding TranslatedText}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                    <Setter TargetName="MessageBorder" Property="Background" Value="#FEE2E2"/>
                                    <Setter TargetName="MessageBorder" Property="BorderBrush" Value="#FCA5A5"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Status Indicator -->
            <Border Grid.Row="2" Background="#FFFFFF" CornerRadius="0,0,12,12" Padding="10,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#34C759" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Sẵn sàng" FontSize="11" Foreground="#8E8E93" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>